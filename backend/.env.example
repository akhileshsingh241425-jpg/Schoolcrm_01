FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this
JWT_SECRET_KEY=your-jwt-secret-change-this

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=school_crm
DB_USER=root
DB_PASSWORD=your-db-password

# Mail
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Upload
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# WhatsApp Cloud API (Tata Telebusiness)
WHATSAPP_API_URL=https://wb.omni.tatatelebusiness.com/whatsapp-cloud/messages
WHATSAPP_AUTH_TOKEN=your-whatsapp-auth-token
WHATSAPP_PHONE=your-whatsapp-phone-number
WHATSAPP_TEMPLATE=pack_dispatch

# SensiBOT WhatsApp API
SENSIBOT_API_TOKEN=your-sensibot-api-token

# IVR Solutions Click-to-Call
IVR_API_URL=https://api.ivrsolutions.in/api/c2c_get
IVR_API_TOKEN=your-ivr-api-token
IVR_DID_NO=
IVR_EXT_NO=
